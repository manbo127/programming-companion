# Application
APP_ENV=production
FLASK_SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
TRUST_PROXY_HOPS=1
SESSION_COOKIE_SECURE=true
CLIENT_COOKIE_SECURE=true
MAX_CONTENT_LENGTH=2097152

# DeepSeek API
DEEPSEEK_API_KEY=sk-replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=35
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_TOTAL_TIMEOUT=40

# SQLite absolute path (four slashes are required)
DATABASE_URL=sqlite:////srv/codemate/instance/companion.db

# Logging
LOG_LEVEL=INFO
