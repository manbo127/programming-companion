# DeepSeek API
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=35

# Flask
APP_ENV=development
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false
TRUST_PROXY_HOPS=0
SESSION_COOKIE_SECURE=false
CLIENT_COOKIE_SECURE=false
MAX_CONTENT_LENGTH=2097152

# Database (SQLite default, replace for Postgres/MySQL later)
DATABASE_URL=sqlite:///instance/companion.db

# Logging
LOG_LEVEL=INFO
